# ── Neon Postgres ────────────────────────────────────────────────────────────
# Copy your connection string from Neon dashboard → Project → Connection Details
# Choose the "Pooled connection" string (ends in ?sslmode=require)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── API shared secret ─────────────────────────────────────────────────────────
# Protects /api/state and /api/extract. Generate with: openssl rand -hex 32
API_SECRET=""
VITE_API_SECRET=""   # must match API_SECRET exactly

# ── Gemini API key (for scoresheet extraction) ────────────────────────────────
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
